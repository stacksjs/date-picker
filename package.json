{
  "name": "date-picker",
  "type": "module",
  "version": "0.11.0",
  "description": "The easy way to start your Vue 3 Component Library.",
  "author": "Chris Breuer <chris@ow3.org>",
  "license": "MIT",
  "homepage": "https://github.com/openweblabs/vue-component-library-starter#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/openweblabs/vue-component-library-starter.git"
  },
  "bugs": {
    "url": "https://github.com/openweblabs/vue-component-library-starter/issues"
  },
  "keywords": [
    "component",
    "library",
    "vue",
    "typescript",
    "javascript",
    "starter",
    "kit"
  ],
  "contributors": [
    "Chris Breuer <chris@ow3.org>"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/my-lib.umd.js",
      "import": "./dist/my-lib.es.js"
    }
  },
  "main": "./dist/my-lib.umd.js",
  "module": "./dist/my-lib.es.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "vite build && pnpm run typecheck",
    "dev": "vite dev --open --port 3333",
    "commit": "git-cz",
    "coverage": "vitest run --coverage",
    "test": "vitest",
    "lint": "bunx --bun pickier .",
    "lint:fix": "bunx --bun pickier . --fix",
    "changelog": "bunx logsmith --verbose",
    "changelog:generate": "bunx logsmith --output CHANGELOG.md",
    "release": "bun --bun run changelog:generate && bunx --bun bumpx prompt --recursive",
    "postinstall": "bunx git-hooks",
    "test:e2e": "cypress open",
    "test:unit": "vitest",
    "typecheck": "vue-tsc --emitDeclarationOnly",
    "format": "bunx --bun pickier . --format",
    "format:fix": "bunx --bun pickier . --format --write"
  },
  "git-hooks": {
    "pre-commit": {
      "staged-lint": {
        "*.{js,ts,json,yaml,yml,md}": "bunx --bun pickier lint --fix"
      }
    },
    "commit-msg": "bunx gitlint --edit .git/COMMIT_EDITMSG"
  },
  "dependencies": {
    "date-fns": "^2.30.0",
    "vue": "^3.5.33"
  },
  "devDependencies": {
    "@babel/types": "^7.29.0",
    "@commitlint/cli": "^17.8.1",
    "@commitlint/config-conventional": "^17.8.1",
    "@commitlint/cz-commitlint": "^17.8.1",
    "@commitlint/types": "^17.8.1",
    "@iconify-json/heroicons-outline": "^1.2.1",
    "@iconify-json/heroicons-solid": "^1.2.1",
    "@types/node": "^17.0.45",
    "@vitejs/plugin-vue": "^2.3.4",
    "@vue/compiler-sfc": "^3.5.33",
    "@vueuse/core": "^8.9.4",
    "commitizen": "^4.3.1",
    "cypress": "^10.11.0",
    "inquirer": "^8.2.7",
    "minimist": "^1.2.8",
    "prompts": "^2.4.2",
    "typescript": "^4.9.5",
    "unplugin-auto-import": "^0.19.0",
    "unplugin-vue-components": "^0.28.0",
    "upath": "^2.0.1",
    "vite": "^2.9.18",
    "vitest": "^0.34.6",
    "vue-tsc": "^0.40.13",
    "bun-git-hooks": "^0.3.1"
  },
  "config": {
    "commitizen": {
      "path": "@commitlint/cz-commitlint"
    }
  }
}
